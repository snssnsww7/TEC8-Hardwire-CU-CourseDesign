<mxfile host="app.diagrams.net">
  <diagram id="karnaugh_sel_full_standard" name="SEL3/SEL2/SEL1/SEL0标准卡诺图">
    <mxGraphModel dx="1320" dy="890" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===================== 左上 SEL3 卡诺图 ===================== -->
        <mxCell id="title_sel3" value="SEL3 卡诺图 | 行变量：ST0，列变量：W1W2" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="330" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="table_sel3" value="&lt;table border='1' cellpadding='7' cellspacing='0'&gt;
&lt;tr&gt;&lt;th rowspan='2'&gt;ST0&lt;/th&gt;&lt;th colspan='2'&gt;W1W2 组合&lt;/th&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;th&gt;01（仅W2有效）&lt;/th&gt;&lt;th&gt;10（仅W1有效）&lt;/th&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;" style="html=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1" vertex="1" parent="1">
          <mxGeometry x="20" y="45" width="310" height="135" as="geometry"/>
        </mxCell>
        <!-- 精准红椭圆：框住ST0=1整行两个格子 -->
        <mxCell id="circle_sel3" value="" style="ellipse;strokeColor=#ff0000;strokeWidth=2;fillColor=none" vertex="1" parent="1">
          <mxGeometry x="108" y="110" width="176" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="expr_sel3" value="化简结果：SEL3 = ST0" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="20" y="190" width="220" height="26" as="geometry"/>
        </mxCell>

        <!-- ===================== 右上 SEL2 卡诺图 ===================== -->
        <mxCell id="title_sel2" value="SEL2 卡诺图 | 行变量：ST0，列变量：W1W2" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1" vertex="1" parent="1">
