<mxfile host="app.diagrams.net">
  <diagram id="karnaugh_sel" name="SEL3~SEL0卡诺图化简">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- ========== 1. SEL3 卡诺图 ========== -->
        <mxCell id="title_sel3" value="SEL3 卡诺图" style="text;html=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="150" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="sel3_table" value="&lt;table border='1' cellpadding='6'&gt;&lt;tr&gt;&lt;th&gt;ST0\W1W2&lt;/th&gt;&lt;th&gt;01(W2)&lt;/th&gt;&lt;th&gt;10(W1)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="html=1;whiteSpace=wrap;fillColor=white;strokeColor=black" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="sel3_circle" value="" style="ellipse;strokeColor=#ff0000;strokeWidth=2;fillColor=none;dashed=0" vertex="1" parent="1">
          <mxGeometry x="130" y="122" width="165" height="52" as="geometry"/>
        </mxCell>
        <mxCell id="sel3_expr" value="SEL3 = ST0" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="20" y="190" width="200" height="25" as="geometry"/>
        </mxCell>

        <!-- ========== 2. SEL2 卡诺图 ========== -->
        <mxCell id="title_sel2" value="SEL2 卡诺图" style="text;html=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="150" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="sel2_table" value="&lt;table border='1' cellpadding='6'&gt;&lt;tr&gt;&lt;th&gt;ST0\W1W2&lt;/th&gt;&lt;th&gt;01(W2)&lt;/th&gt;&lt;th&gt;10(W1)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="html=1;whiteSpace=wrap;fillColor=white;strokeColor=black" vertex="1" parent="1">
          <mxGeometry x="350" y="60" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="sel2_circle" value="" style="ellipse;strokeColor=#ff0000;strokeWidth=2;fillColor=none;dashed=0" vertex="1" parent="1">
          <mxGeometry x="440" y="68" width="70" height="106" as="geometry"/>
        </mxCell>
        <mxCell id="sel2_expr" value="SEL2 = W2" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="350" y="190" width="200" height="25" as="geometry"/>
        </mxCell>

        <!-- ========== 3. SEL0 卡诺图 ========== -->
        <mxCell id="title_sel0" value="SEL0 卡诺图" style="text;html=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="240" width="150" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="sel0_table" value="&lt;table border='1' cellpadding='6'&gt;&lt;tr&gt;&lt;th&gt;ST0\W1W2&lt;/th&gt;&lt;th&gt;01(W2)&lt;/th&gt;&lt;th&gt;10(W1)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="html=1;whiteSpace=wrap;fillColor=white;strokeColor=black" vertex="1" parent="1">
          <mxGeometry x="20" y="280" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="sel0_circle" value="" style="ellipse;strokeColor=#ff0000;strokeWidth=2;fillColor=none;dashed=0" vertex="1" parent="1">
          <mxGeometry x="230" y="68" width="70" height="106" as="geometry"/>
        </mxCell>
        <mxCell id="sel0_expr" value="SEL0 = W1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="20" y="410" width="200" height="25" as="geometry"/>
        </mxCell>

        <!-- ========== 4. SEL1 核心卡诺图（带两组圈选） ========== -->
        <mxCell id="title_sel1" value="SEL1 卡诺图（核心）" style="text;html=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="350" y="240" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="sel1_table" value="&lt;table border='1' cellpadding='6'&gt;&lt;tr&gt;&lt;th&gt;ST0\W1W2&lt;/th&gt;&lt;th&gt;01(W2)&lt;/th&gt;&lt;th&gt;10(W1)&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="html=1;whiteSpace=wrap;fillColor=white;strokeColor=black" vertex="1" parent="1">
          <mxGeometry x="350" y="280" width="280" height="120" as="geometry"/>
        </mxCell>
        <!-- 圈1：右列W1全部单元格 -->
        <mxCell id="sel1_c1" value="" style="ellipse;strokeColor=#ff0000;strokeWidth=2;fillColor=none" vertex="1" parent="1">
          <mxGeometry x="530" y="288" width="72" height="104" as="geometry"/>
        </mxCell>
        <!-- 圈2：左下 ST0=1,W2=1 单元格 -->
        <mxCell id="sel1_c2" value="" style="ellipse;strokeColor=#0000ff;strokeWidth=2;fillColor=none" vertex="1" parent="1">
          <mxGeometry x="432" y="342" width="62" height="48" as="geometry"/>
        </mxCell>
        <!-- ===== 关键修复：这里的 & 全部改成 &amp; ===== -->
        <mxCell id="sel1_expr" value="SEL1 = W1 | (ST0 &amp; W2) = (~ST0 &amp; W1) | (ST0 &amp; W2)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="350" y="410" width="320" height="25" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
