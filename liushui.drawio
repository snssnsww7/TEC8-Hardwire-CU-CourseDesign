<mxfile host="app.diagrams.net">
  <diagram name="顺序式与流水线指令周期对比">
    <mxGraphModel dx="1000" dy="1100" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- 第一组：顺序式指令周期 -->
        <!-- 第一个周期块：取指令+执行 -->
        <mxCell id="sq_fetch1" value="取指令" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="180" height="120"/>
        </mxCell>
        <mxCell id="sq_exec1" value="执行" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000" vertex="1" parent="1">
          <mxGeometry x="260" y="80" width="180" height="120"/>
        </mxCell>
        <!-- 第二个周期块：取指令+执行（错开右移） -->
        <mxCell id="sq_fetch2" value="取指令" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000" vertex="1" parent="1">
          <mxGeometry x="440" y="200" width="180" height="120"/>
        </mxCell>
        <mxCell id="sq_exec2" value="执行" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000" vertex="1" parent="1">
          <mxGeometry x="620" y="200" width="180" height="120"/>
        </mxCell>
        <!-- 顺序式大括号文字 -->
        <mxCell id="sq_label" value="顺序式指令周期" style="text;html=1;fontSize=16" vertex="1" parent="1">
          <mxGeometry x="320" y="340" width="220" height="40"/>
        </mxCell>
        <mxCell id="sq_brace" value="「」" style="text;html=1;fontSize=60;align=center" vertex="1" parent="1">
          <mxGeometry x="300" y="310" width="260" height="80"/>
        </mxCell>

        <!-- 中间向下箭头 -->
        <mxCell id="arrow_down" edge="1" parent="1" source="" target="">
          <mxGeometry x="480" y="400" width="0" height="80"/>
          <mxStyle endArrow="block;html=1;strokeWidth=2"/>
        </mxCell>

        <!-- 第二组：流水线指令周期 -->
        <!-- 第一行：取指令+执行 -->
        <mxCell id="pl_fetch1" value="取指令" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="180" height="120"/>
        </mxCell>
        <mxCell id="pl_exec1" value="执行" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000" vertex="1" parent="1">
          <mxGeometry x="260" y="500" width="180" height="120"/>
        </mxCell>
        <!-- 第二行：取指令+执行（向下对齐重叠） -->
        <mxCell id="pl_fetch2" value="取指令" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000" vertex="1" parent="1">
          <mxGeometry x="260" y="620" width="180" height="120"/>
        </mxCell>
        <mxCell id="pl_exec2" value="执行" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000" vertex="1" parent="1">
          <mxGeometry x="440" y="620" width="180" height="120"/>
        </mxCell>
        <!-- 流水线大括号文字 -->
        <mxCell id="pl_label" value="流水线指令周期" style="text;html=1;fontSize=16" vertex="1" parent="1">
          <mxGeometry x="320" y="760" width="220" height="40"/>
        </mxCell>
        <mxCell id="pl_brace" value="「」" style="text;html=1;fontSize=60;align=center" vertex="1" parent="1">
          <mxGeometry x="300" y="730" width="260" height="80"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
