<mxfile host="app.diagrams.net">
  <diagram id="cu_ctrl_int_flow" name="硬连线控制器节拍流程图">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- 配色定义：W1=#E8F5E9浅绿 W2=#FFF3CD浅黄 W3=#FFE5D9浅橙 判断=#E3F2FD浅蓝 跳转中断=#FDE2E4浅红 访存=#FFD7BA -->
        <!-- 顶部CLR椭圆 -->
        <mxCell id="clr" value="CLR" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D9EAF7;strokeColor=#6C757D;fontColor=#212529;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="520" y="20" width="100" height="40" as="geometry"/>
        </mxCell>
        <!-- CLR向下箭头 -->
        <mxCell id="arrow_clr_sw" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="clr" target="sw_dia">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- SWC SWB SWA 判断菱形 -->
        <mxCell id="sw_dia" value="SWC SWB SWA" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6C757D;fontColor=#212529;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- 上方5列顶层标识：100写寄存器 011读寄存器 010读存储器 001写存储器 000取指 -->
        <mxCell id="lab_100" value="100&lt;br/&gt;写寄存器" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C757D;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="100" y="160" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="lab_011" value="011&lt;br/&gt;读寄存器" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C757D;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="240" y="160" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="lab_010" value="010&lt;br/&gt;读存储器" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C757D;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="380" y="160" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="lab_001" value="001&lt;br/&gt;写存储器" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C757D;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="520" y="160" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="lab_000" value="000&lt;br/&gt;取指" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C757D;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="660" y="160" width="120" height="30" as="geometry"/>
        </mxCell>

        <!-- 右侧纵向节拍标签 W1 W2 W3 -->
        <mxCell id="lab_w1_top" value="W1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6C757D;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="820" y="200" width="40" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="lab_w2_top" value="W2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="820" y="330" width="40" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="lab_w1_mid" value="W1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6C757D;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="820" y="480" width="40" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="lab_w2_mid" value="W2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="820" y="550" width="40" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="lab_w3_bot" value="W3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE5D9;strokeColor=#6C757D;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="820" y="740" width="40" height="120" as="geometry"/>
        </mxCell>

        <!-- ========== 第一大区域：SWCBA 000/001/010/011/100 W1(绿) W2(黄) ========== -->
        <!-- 100 写寄存器 W1 ST0=0 -->
        <mxCell id="w1_100_st0_0" value="SBUS&lt;br/&gt;SEL3=0&lt;br/&gt;SEL2=1&lt;br/&gt;SEL1=0&lt;br/&gt;SEL0=1&lt;br/&gt;SELCTL&lt;br/&gt;DRW STOP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="120" height="120" as="geometry"/>
        </mxCell>
        <!-- 100 写寄存器 W1 ST0=1 -->
        <mxCell id="w1_100_st0_1" value="SBUS&lt;br/&gt;SEL3=1&lt;br/&gt;SEL2=1&lt;br/&gt;SEL1=0&lt;br/&gt;SEL0=1&lt;br/&gt;SELCTL&lt;br/&gt;DRW STOP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="100" y="330" width="120" height="120" as="geometry"/>
        </mxCell>
        <!-- 100 W2 -->
        <mxCell id="w2_100" value="SBUS&lt;br/&gt;SEL3=1&lt;br/&gt;SEL2=1&lt;br/&gt;SEL1=0&lt;br/&gt;SEL0=1&lt;br/&gt;SELCTL&lt;br/&gt;STOP DRW&lt;br/&gt;SST0" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="100" y="460" width="120" height="100" as="geometry"/>
        </mxCell>

        <!-- 011 读寄存器 W1 -->
        <mxCell id="w1_011" value="SEL3=1&lt;br/&gt;SEL2=0&lt;br/&gt;SEL1=1&lt;br/&gt;SEL0=1&lt;br/&gt;SELCTL&lt;br/&gt;STOP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="240" y="200" width="120" height="120" as="geometry"/>
        </mxCell>
        <!-- 011 W2 -->
        <mxCell id="w2_011" value="SBUS&lt;br/&gt;SEL3=1&lt;br/&gt;SEL2=1&lt;br/&gt;SEL1=1&lt;br/&gt;SEL0=1&lt;br/&gt;SELCTL&lt;br/&gt;STOP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="240" y="330" width="120" height="230" as="geometry"/>
        </mxCell>

        <!-- 010 读存储器 W1 ST0=0 -->
        <mxCell id="w1_010_st0_0" value="SBUS LAR&lt;br/&gt;STOP&lt;br/&gt;SST0&lt;br/&gt;SHORT SELCTL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="200" width="120" height="120" as="geometry"/>
        </mxCell>
        <!-- 010 W1 ST0=1 -->
        <mxCell id="w1_010_st0_1" value="MBUS ARINC&lt;br/&gt;STOP SHORT&lt;br/&gt;SELCTL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="330" width="120" height="120" as="geometry"/>
        </mxCell>
        <!-- 010 W2 -->
        <mxCell id="w2_010" value="SBUS&lt;br/&gt;SEL3=1&lt;br/&gt;SEL2=1&lt;br/&gt;SEL1=1&lt;br/&gt;SEL0=1&lt;br/&gt;SELCTL&lt;br/&gt;STOP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="460" width="120" height="100" as="geometry"/>
        </mxCell>

        <!-- 001 写存储器 W1 ST0=0 -->
        <mxCell id="w1_001_st0_0" value="SBUS LAR&lt;br/&gt;STOP&lt;br/&gt;SST0&lt;br/&gt;SHORT SELCTL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="520" y="200" width="120" height="120" as="geometry"/>
        </mxCell>
        <!-- 001 W1 ST0=1 -->
        <mxCell id="w1_001_st0_1" value="SBUS MEMW&lt;br/&gt;ARINC&lt;br/&gt;STOP SHORT&lt;br/&gt;SELCTL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="520" y="330" width="120" height="120" as="geometry"/>
        </mxCell>
        <!-- 001 W2 -->
        <mxCell id="w2_001" value="SBUS&lt;br/&gt;SEL3=1&lt;br/&gt;SEL2=1&lt;br/&gt;SEL1=1&lt;br/&gt;SEL0=1&lt;br/&gt;SELCTL&lt;br/&gt;STOP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="520" y="460" width="120" height="100" as="geometry"/>
        </mxCell>

        <!-- 000 取指 W1 ST0=0 / ST0=1 合并 -->
        <mxCell id="w1_000" value="LIR PCINC" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="660" y="200" width="120" height="250" as="geometry"/>
        </mxCell>

        <!-- 中间 IR7~IR4 菱形 -->
        <mxCell id="ir_dia" value="IR7~R4" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6C757D;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="360" y="480" width="160" height="60" as="geometry"/>
        </mxCell>
        <!-- 取指区指向IR菱形箭头 -->
        <mxCell id="arrow_000_ir" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="w1_000" target="ir_dia">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== 第二大区域：指令译码 W2(黄) ========== -->
        <!-- ADD 0001 -->
        <mxCell id="inst_add" value="0001 ADD&lt;br/&gt;S=1001 CIN&lt;br/&gt;ABUS DRW&lt;br/&gt;LDZ LDC" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="60" y="550" width="75" height="180" as="geometry"/>
        </mxCell>
        <!-- SUB 0010 -->
        <mxCell id="inst_sub" value="0010 SUB&lt;br/&gt;S=0110&lt;br/&gt;ABUS DRW&lt;br/&gt;LDZ LDC" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="145" y="550" width="75" height="180" as="geometry"/>
        </mxCell>
        <!-- AND 0011 -->
        <mxCell id="inst_and" value="0011 AND&lt;br/&gt;M S=1011&lt;br/&gt;ABUS DRW LDZ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="230" y="550" width="75" height="180" as="geometry"/>
        </mxCell>
        <!-- INC 0100 -->
        <mxCell id="inst_inc" value="0100 INC&lt;br/&gt;S=0000&lt;br/&gt;ABUS DRW&lt;br/&gt;LDZ LDC" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="315" y="550" width="75" height="180" as="geometry"/>
        </mxCell>
        <!-- LD 0101 访存浅橙 -->
        <mxCell id="inst_ld" value="0101 LD&lt;br/&gt;M S=1010&lt;br/&gt;ABUS LAR&lt;br/&gt;LONG" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFD7BA;strokeColor=#6C757D;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="400" y="550" width="75" height="180" as="geometry"/>
        </mxCell>
        <!-- ST 0110 访存浅橙 -->
        <mxCell id="inst_st" value="0110 ST&lt;br/&gt;M S=1111&lt;br/&gt;ABUS LAR&lt;br/&gt;LONG" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFD7BA;strokeColor=#6C757D;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="485" y="550" width="75" height="180" as="geometry"/>
        </mxCell>
        <!-- JC 0111 跳转浅红 -->
        <mxCell id="inst_jc" value="0111 JC&lt;br/&gt;C=0:无&lt;br/&gt;C=1:PCADD" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FDE2E4;strokeColor=#6C757D;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="570" y="550" width="75" height="180" as="geometry"/>
        </mxCell>
        <!-- JZ 1000 跳转浅红 -->
        <mxCell id="inst_jz" value="1000 JZ&lt;br/&gt;Z=0:无&lt;br/&gt;Z=1:PCADD" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FDE2E4;strokeColor=#6C757D;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="655" y="550" width="75" height="180" as="geometry"/>
        </mxCell>
        <!-- JMP 1001 跳转浅红 -->
        <mxCell id="inst_jmp" value="1001 JMP&lt;br/&gt;M S=1111&lt;br/&gt;ABUS LPC" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FDE2E4;strokeColor=#6C757D;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="740" y="550" width="75" height="180" as="geometry"/>
        </mxCell>
        <!-- STP 1110 -->
        <mxCell id="inst_stp" value="1110 STP&lt;br/&gt;STOP" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#6C757D;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="825" y="550" width="75" height="180" as="geometry"/>
        </mxCell>

        <!-- IR菱形指向所有指令箭头 -->
        <mxCell id="arrow_ir_add" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="ir_dia" target="inst_add"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arrow_ir_sub" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="ir_dia" target="inst_sub"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arrow_ir_and" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="ir_dia" target="inst_and"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arrow_ir_inc" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="ir_dia" target="inst_inc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arrow_ir_ld" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="ir_dia" target="inst_ld"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arrow_ir_st" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="ir_dia" target="inst_st"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arrow_ir_jc" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="ir_dia" target="inst_jc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arrow_ir_jz" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="ir_dia" target="inst_jz"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arrow_ir_jmp" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="ir_dia" target="inst_jmp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arrow_ir_stp" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="ir_dia" target="inst_stp"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ========== 第三大区域：W3节拍 访存回写（浅橙） ========== -->
        <mxCell id="w3_ldst" value="DRW MBUS&lt;br/&gt;M S=1010&lt;br/&gt;ABUS MEMW" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE5D9;strokeColor=#6C757D;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="400" y="740" width="160" height="120" as="geometry"/>
        </mxCell>
        <!-- LD/ST指向W3箭头 -->
        <mxCell id="arrow_ld_w3" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="inst_ld" target="w3_ldst"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="arrow_st_w3" value="" style="endArrow=block;html=1;strokeWidth=1" edge="1" parent="1" source="inst_st" target="w3_ldst"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
